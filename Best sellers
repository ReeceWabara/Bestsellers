// === UTILS ===
const fmt$ = n => n >= 1e6 ? '£'+( n/1e6).toFixed(1)+'M' : n >= 1e3 ? '£'+(n/1e3).toFixed(n>=1e5?0:1)+'K' : '£'+n.toFixed(0);
const fmtN = n => n >= 1e6 ? (n/1e6).toFixed(1)+'M' : n >= 1e3 ? (n/1e3).toFixed(n>=1e4?0:1)+'K' : n.toFixed(0);
const fmtPct = n => (n*100).toFixed(0)+'%';

