// === KPI BAR ===
function renderKPIs() {
  const totalRev = D.reduce((s,p) => s+p.r, 0);
  const totalVol = D.reduce((s,p) => s+p.v, 0);
  const avgRev = totalRev / D.length;
  const onDisc = D.filter(p => p.d > 0).length;
  const discPct = onDisc / D.length;
  const avgPrice = D.reduce((s,p) => s+p.p, 0) / D.length;
  const avgVel = D.reduce((s,p) => s+p.v/28, 0) / D.length;
  const topVel = Math.max(...D.map(p => p.v/28));

  document.getElementById('kpiBar').innerHTML = [
    {l:'Total Revenue', v:fmt$(totalRev), s:'est. 4-week period'},
    {l:'Products Tracked', v:fmtN(D.length), s:BRANDS.length+' brands'},
    {l:'Total Units', v:fmtN(totalVol), s:'est. sell-through'},
    {l:'Avg Velocity', v:avgVel.toFixed(1)+'/day', s:'top: '+topVel.toFixed(0)+'/day'},
    {l:'Avg Rev / Product', v:fmt$(avgRev), s:'across all brands'},
    {l:'Avg Price Point', v:'£'+avgPrice.toFixed(0), s:fmtPct(discPct)+' on discount'},
  ].map(k => `<div class="kpi-card"><div class="kpi-label">${k.l}</div><div class="kpi-value">${k.v}</div><div class="kpi-sub">${k.s}</div></div>`).join('');
}

// === BRAND LEADERBOARD ===
function renderBrandBoard() {
  const agg = {};
  D.forEach(p => {
    if(!agg[p.b]) agg[p.b] = {rev:0,vol:0,count:0,disc:0,vel:0};
    agg[p.b].rev += p.r;
    agg[p.b].vol += p.v;
    agg[p.b].count++;
    agg[p.b].vel += p.v/28;
    if(p.d>0) agg[p.b].disc++;
  });
  const sorted = Object.entries(agg).sort((a,b) => b[1].rev - a[1].rev);
  const maxRev = sorted[0][1].rev;

  document.getElementById('brandBoard').innerHTML = sorted.map(([name,d],i) => {
    const pct = (d.rev/maxRev*100).toFixed(1);
    const avgRev = d.rev/d.count;
    const color = BRAND_COLORS[name];
    return `<div class="brand-row">
      <div class="name"><span class="rank">${i+1}</span>
        <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:${color}"></span>
        ${name}</div>
      <div class="brand-bar-wrap"><div class="brand-bar" style="width:${pct}%;background:linear-gradient(90deg,${color},${color}88)"></div></div>
      <div class="brand-rev">${fmt$(d.rev)}</div>
      <div class="brand-vol">${fmtN(d.vol)} units</div>
      <div class="brand-avg">${fmtN(d.count)} SKUs &middot; ${fmt$(avgRev)}/ea &middot; ${(d.vel/d.count).toFixed(1)}/day avg</div>
    </div>`;
  }).join('');
}

// === IMAGE LOADER ===
function loadImage(img, src, productUrl) {
  if(!src && !productUrl) { showPH(img); return; }
  if(!src) { tryShopifyJSON(img, productUrl); return; }

  img.referrerPolicy = 'no-referrer';
  img.onload = () => {};
  img.onerror = () => {
    const proxy1 = 'https://wsrv.nl/?url='+encodeURIComponent(src)+'&w=400&output=jpg&q=75';
    img.onload = () => {};
    img.onerror = () => {
      if(productUrl) tryShopifyJSON(img, productUrl);
      else showPH(img);
    };
    img.src = proxy1;
  };
  img.src = src;
}

function tryShopifyJSON(img, url) {
  if(!url || !url.includes('/products/')) { showPH(img); return; }
  let jsonUrl = url.replace(/\.html$/,'') + '.json';
  fetch('https://corsproxy.io/?'+encodeURIComponent(jsonUrl))
    .then(r => r.json())
    .then(data => {
      const imgSrc = data?.product?.image?.src || data?.product?.images?.[0]?.src;
      if(imgSrc) { img.src = imgSrc; img.onerror = () => showPH(img); }
      else showPH(img);
    })
    .catch(() => showPH(img));
}

function showPH(img) {
  const ph = img.parentElement?.querySelector('.img-placeholder, .hit-img-ph');
  if(ph) { ph.style.display = 'flex'; img.style.display = 'none'; }
  else { img.style.display = 'none'; }
}

// === PRODUCTS PANEL ===
function buildBrandChips(containerId, filterSet, callback) {
  const el = document.getElementById(containerId);
  el.innerHTML = '<div class="chip active" data-brand="all">All Brands</div>' +
    BRANDS.map(b => `<div class="chip" data-brand="${b}"><span style="display:inline-block;width:6px;height:6px;border-radius:50%;background:${BRAND_COLORS[b]};margin-right:3px"></span>${b}</div>`).join('');

  el.addEventListener('click', e => {
    const chip = e.target.closest('.chip');
    if(!chip) return;
    const brand = chip.dataset.brand;
    if(brand === 'all') {
      filterSet.clear();
      el.querySelectorAll('.chip').forEach(c => c.classList.toggle('active', c.dataset.brand==='all'));
    } else {
      if(filterSet.has(brand)) filterSet.delete(brand); else filterSet.add(brand);
      el.querySelector('[data-brand="all"]').classList.toggle('active', filterSet.size===0);
      el.querySelectorAll('.chip:not([data-brand="all"])').forEach(c => c.classList.toggle('active', filterSet.has(c.dataset.brand)));
    }
    callback();
  });
}

function getFilteredProducts(filterSet) {
  let data = D;
  if(filterSet.size > 0) data = data.filter(p => filterSet.has(p.b));
  return data;
}

function getSortedProducts(data) {
  const s = [...data];
  switch(productSort) {
    case 'revenue': s.sort((a,b) => b.r - a.r); break;
    case 'volume': s.sort((a,b) => b.v - a.v); break;
    case 'price-hi': s.sort((a,b) => b.p - a.p); break;
    case 'discount': s.sort((a,b) => b.d - a.d); break;
    case 'velocity': s.sort((a,b) => (b.v/28) - (a.v/28)); break;
  }
  return s;
}

function renderProducts() {
  const filtered = getFilteredProducts(productBrandFilter);
  const sorted = getSortedProducts(filtered);
  const totalPages = Math.ceil(sorted.length / PAGE_SIZE);
  if(productPage >= totalPages) productPage = totalPages - 1;
  if(productPage < 0) productPage = 0;
  const start = productPage * PAGE_SIZE;
  const page = sorted.slice(start, start + PAGE_SIZE);

  document.getElementById('productsCount').textContent =
    `${filtered.length.toLocaleString()} products · ${fmt$(filtered.reduce((s,p)=>s+p.r,0))} total revenue`;

  const grid = document.getElementById('productsGrid');
  grid.innerHTML = page.map((p,i) => {
    const globalRank = start + i + 1;
    const hasDisc = p.d > 0;
    const vel = p.v / 28;
    return `<div class="product-card">
      <a href="${p.u}" target="_blank" rel="noopener">
        <div class="card-img-wrap">
          <img src="" alt="${p.t}" loading="lazy" style="display:none">
          <div class="img-placeholder">No Image</div>
          <div class="card-rank">#${globalRank}</div>
          ${hasDisc ? `<div class="card-discount">-${fmtPct(p.d)}</div>` : ''}
          ${vel >= 0.1 ? `<div class="card-velocity">${vel >= 10 ? vel.toFixed(0) : vel.toFixed(1)}<span class="v-unit">/day</span></div>` : ''}
        </div>
        <div class="card-body">
          <div class="card-brand">${p.b}</div>
          <div class="card-title">${p.t}</div>
          <div class="card-metrics">
            <div>
              <div class="card-revenue">${fmt$(p.r)}</div>
              <div class="card-volume">${fmtN(p.v)} units &middot; ${vel >= 10 ? vel.toFixed(0) : vel.toFixed(1)}/day</div>
            </div>
            <div class="card-price">
              ${hasDisc ? `<div class="full">£${p.fp.toFixed(0)}</div>` : ''}
              £${p.p.toFixed(0)}
            </div>
          </div>
        </div>
      </a>
    </div>`;
  }).join('');

  // Load images
  grid.querySelectorAll('.product-card').forEach((card,i) => {
    const p = page[i];
    const img = card.querySelector('img');
    const ph = card.querySelector('.img-placeholder');
    if(p.i) {
      img.style.display = 'block';
      ph.style.display = 'none';
      loadImage(img, p.i, p.u);
    }
  });

  // Pagination
  renderPagination(totalPages);
}

function renderPagination(totalPages) {
  if(totalPages <= 1) { document.getElementById('pagination').innerHTML = ''; return; }
  const el = document.getElementById('pagination');
  let html = `<button ${productPage===0?'disabled':''} onclick="productPage=0;renderProducts();">«</button>`;
  html += `<button ${productPage===0?'disabled':''} onclick="productPage--;renderProducts();">‹</button>`;

  const start = Math.max(0, productPage-2);
  const end = Math.min(totalPages-1, productPage+2);
  for(let i=start; i<=end; i++) {
    html += `<button class="${i===productPage?'active':''}" onclick="productPage=${i};renderProducts();">${i+1}</button>`;
  }

  html += `<button ${productPage>=totalPages-1?'disabled':''} onclick="productPage++;renderProducts();">›</button>`;
  html += `<button ${productPage>=totalPages-1?'disabled':''} onclick="productPage=${totalPages-1};renderProducts();">»</button>`;
  html += `<span class="page-info">${productPage+1}/${totalPages}</span>`;
  el.innerHTML = html;
}

// Sort buttons
document.getElementById('sortBar').addEventListener('click', e => {
  const btn = e.target.closest('.sort-btn');
  if(!btn) return;
  productSort = btn.dataset.sort;
  productPage = 0;
  document.querySelectorAll('.sort-btn').forEach(b => b.classList.toggle('active', b===btn));
  renderProducts();
});

// === CATEGORIES ===
function renderCategories() {
  const data = getFilteredProducts(catBrandFilter);
  const cats = {};
  data.forEach(p => {
    const c = p.c || 'Other';
    if(!cats[c]) cats[c] = {rev:0, count:0, vol:0};
    cats[c].rev += p.r;
    cats[c].count++;
    cats[c].vol += p.v;
  });
  const sorted = Object.entries(cats).sort((a,b) => b[1].rev - a[1].rev);
  const maxRev = sorted[0]?.[1]?.rev || 1;
  const top25 = sorted.slice(0, 25);

  // SVG bar chart
  const chartW = 800, barH = 22, gap = 4, padL = 140, padR = 80;
  const chartH = top25.length * (barH + gap) + 20;
  let svg = `<svg viewBox="0 0 ${chartW} ${chartH}" class="chart-canvas">`;
  top25.forEach(([name, d], i) => {
    const y = i * (barH + gap) + 10;
    const w = (d.rev / maxRev) * (chartW - padL - padR);
    svg += `<text x="${padL-8}" y="${y+barH/2+4}" text-anchor="end" fill="#8a8a8e" font-size="11">${name}</text>`;
    svg += `<rect x="${padL}" y="${y}" width="${w}" height="${barH}" rx="3" fill="var(--accent)" opacity=".7"/>`;
    svg += `<text x="${padL+w+6}" y="${y+barH/2+4}" fill="#e8e6e1" font-size="11" font-family="var(--mono)">${fmt$(d.rev)}</text>`;
  });
  svg += '</svg>';
  document.getElementById('catChart').innerHTML = svg;

  // Grid below
  document.getElementById('catGrid').innerHTML = sorted.map(([name,d]) =>
    `<div class="cat-row">
      <div class="cat-name">${name}</div>
      <div class="cat-rev">${fmt$(d.rev)}</div>
      <div class="cat-count">${d.count} SKUs</div>
    </div>`
  ).join('');
}

// === PRICING ===
function renderPricing() {
  // Price tier distribution
  const tiers = [
    {label:'Under £50', test:p=>p.p<50, color:'#3ecf8e'},
    {label:'£50–100', test:p=>p.p>=50&&p.p<100, color:'#5b9cf6'},
    {label:'£100–200', test:p=>p.p>=100&&p.p<200, color:'#a78bfa'},
    {label:'£200–500', test:p=>p.p>=200&&p.p<500, color:'#fbbf24'},
    {label:'£500–1K', test:p=>p.p>=500&&p.p<1000, color:'#f97066'},
    {label:'£1K+', test:p=>p.p>=1000, color:'#c9a962'}
  ];

  tiers.forEach(t => {
    t.products = D.filter(t.test);
    t.count = t.products.length;
    t.rev = t.products.reduce((s,p)=>s+p.r,0);
  });
  const maxCount = Math.max(...tiers.map(t=>t.count));
  const maxRev = Math.max(...tiers.map(t=>t.rev));

  let html = '<div class="price-card"><div class="price-card-title">Products by Price Tier</div>';
  tiers.forEach(t => {
    html += `<div class="tier-row">
      <div class="tier-label">${t.label}</div>
      <div class="tier-bar-wrap"><div class="tier-bar" style="width:${(t.count/maxCount*100).toFixed(1)}%;background:${t.color}"></div></div>
      <div class="tier-val">${fmtN(t.count)}</div>
    </div>`;
  });
  html += '</div>';

  html += '<div class="price-card"><div class="price-card-title">Revenue by Price Tier</div>';
  tiers.forEach(t => {
    html += `<div class="tier-row">
      <div class="tier-label">${t.label}</div>
      <div class="tier-bar-wrap"><div class="tier-bar" style="width:${(t.rev/maxRev*100).toFixed(1)}%;background:${t.color}"></div></div>
      <div class="tier-val">${fmt$(t.rev)}</div>
    </div>`;
  });
  html += '</div>';

  document.getElementById('priceGrid').innerHTML = html;

  // Discount by brand
  const brandDisc = {};
  D.forEach(p => {
    if(!brandDisc[p.b]) brandDisc[p.b] = {total:0, disc:0, discRev:0, totalRev:0};
    brandDisc[p.b].total++;
    brandDisc[p.b].totalRev += p.r;
    if(p.d > 0) { brandDisc[p.b].disc++; brandDisc[p.b].discRev += p.r; }
  });

  const discSorted = Object.entries(brandDisc).sort((a,b) => (b[1].disc/b[1].total) - (a[1].disc/a[1].total));
  document.getElementById('discBoard').innerHTML = discSorted.map(([name,d]) => {
    const pct = d.disc/d.total;
    const color = BRAND_COLORS[name];
    return `<div class="disc-brand-row">
      <div style="font-size:.8rem;font-weight:500;display:flex;align-items:center;gap:.4rem">
        <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:${color}"></span>
        ${name}
      </div>
      <div class="disc-bar-wrap"><div class="disc-bar" style="width:${(pct*100).toFixed(1)}%;background:${color}"></div></div>
      <div class="disc-pct">${fmtPct(pct)}</div>
      <div class="disc-rev">${fmt$(d.discRev)}</div>
    </div>`;
  }).join('');
}

// === HIT FINDER ===
function renderHits() {
  const revMin = +document.getElementById('hitRevMin').value;
  const volMin = +document.getElementById('hitVolMin').value;
  const velMin = +document.getElementById('hitVelMin').value;
  document.getElementById('hitRevMinVal').textContent = fmt$(revMin);
  document.getElementById('hitVolMinVal').textContent = fmtN(volMin);
  document.getElementById('hitVelMinVal').textContent = velMin.toFixed(1);

  let data = getFilteredProducts(hitBrandFilter);
  const hits = data.filter(p => p.r >= revMin && p.v >= volMin && (p.v/28) >= velMin).sort((a,b) => b.r - a.r);

  const hitRev = hits.reduce((s,p) => s+p.r, 0);
  document.getElementById('hitStats').innerHTML = `
    <div class="stat"><strong>${hits.length}</strong> hits found</div>
    <div class="stat"><strong>${fmt$(hitRev)}</strong> combined revenue</div>
    <div class="stat"><strong>${fmtN(hits.reduce((s,p)=>s+p.v,0))}</strong> total units</div>
    <div class="stat"><strong>${hits.length ? (hits.reduce((s,p)=>s+p.v/28,0)/hits.length).toFixed(1) : '0'}/day</strong> avg velocity</div>
  `;

  const display = hits.slice(0, 100);
  const grid = document.getElementById('hitsGrid');
  grid.innerHTML = display.map(p => `<div class="hit-card">
    <div style="position:relative">
      <img class="hit-img" src="" alt="${p.t}" style="display:none">
      <div class="hit-img-ph">No Image</div>
    </div>
    <div class="hit-body">
      <div class="hit-brand">${p.b}</div>
      <div class="hit-title"><a href="${p.u}" target="_blank" rel="noopener" style="color:inherit;text-decoration:none">${p.t}</a></div>
      <div class="hit-stats">
        <div><div class="hit-stat-label">Revenue</div><div class="hit-stat-val rev">${fmt$(p.r)}</div></div>
        <div><div class="hit-stat-label">Volume</div><div class="hit-stat-val vol">${fmtN(p.v)}</div></div>
        <div><div class="hit-stat-label">Velocity</div><div class="hit-stat-val" style="color:var(--teal)">${(p.v/28).toFixed(1)}/day</div></div>
        <div><div class="hit-stat-label">Price</div><div class="hit-stat-val price">£${p.p.toFixed(0)}</div></div>
      </div>
    </div>
  </div>`).join('');

  // Load hit images
  grid.querySelectorAll('.hit-card').forEach((card,i) => {
    const p = display[i];
    const img = card.querySelector('.hit-img');
    if(p.i) {
      img.style.display = 'block';
      card.querySelector('.hit-img-ph').style.display = 'none';
      loadImage(img, p.i, p.u);
    }
  });
}

document.getElementById('hitRevMin').addEventListener('input', renderHits);
document.getElementById('hitVolMin').addEventListener('input', renderHits);
document.getElementById('hitVelMin').addEventListener('input', renderHits);

// === INIT ===
renderKPIs();
renderBrandBoard();
buildBrandChips('brandChips', productBrandFilter, () => { productPage=0; renderProducts(); });
buildBrandChips('catBrandChips', catBrandFilter, renderCategories);
buildBrandChips('hitBrandChips', hitBrandFilter, renderHits);
renderProducts();
renderCategories();
renderPricing();
renderHits();

</script>
</body>
</html>
