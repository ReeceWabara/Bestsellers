<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Best Sellers Intelligence — Multi-Brand Report</title>
<style>
:root {
  --bg:       #0a0a0c;
  --surface:  #131316;
  --card:     #1a1a1f;
  --border:   #2a2a30;
  --border-lt:#3a3a42;
  --text:     #e8e6e1;
  --text-dim: #8a8a8e;
  --text-mute:#5a5a5e;
  --accent:   #c9a962;
  --accent2:  #d4b87a;
  --green:    #3ecf8e;
  --red:      #ef5350;
  --blue:     #5b9cf6;
  --purple:   #a78bfa;
  --coral:    #f97066;
  --teal:     #2dd4bf;
  --amber:    #fbbf24;
  --font:     'DM Sans', -apple-system, sans-serif;
  --mono:     'JetBrains Mono', 'SF Mono', monospace;
}
@import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,300&family=JetBrains+Mono:wght@400;500&display=swap');

*, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
html { font-size:15px; scroll-behavior:smooth; }
body {
  background:var(--bg);
  color:var(--text);
  font-family:var(--font);
  line-height:1.5;
  -webkit-font-smoothing:antialiased;
}

/* === HEADER === */
.site-header {
  /* not sticky - let it scroll */
  padding:2rem 2.5rem 1.6rem;
  border-bottom:1px solid var(--border);
  background:linear-gradient(180deg, #10101a 0%, var(--bg) 100%);
  
}
.header-eyebrow {
  font-size:.7rem;
  letter-spacing:.14em;
  text-transform:uppercase;
  color:var(--accent);
  margin-bottom:.5rem;
  font-weight:500;
}
.header-title {
  font-size:1.75rem;
  font-weight:300;
  letter-spacing:-.02em;
  color:var(--text);
  line-height:1.2;
}
.header-title em { font-style:normal; color:var(--text-dim); font-weight:300; }
.header-title em::before { content:' / '; color:var(--border-lt); }
.header-period {
  font-size:.75rem; color:var(--text-mute); margin-top:.4rem;
  font-family:var(--mono); font-weight:400;
}

/* === NAV === */
.panel-nav {
  display:flex; gap:.25rem; padding:.8rem 2.5rem;
  border-bottom:1px solid var(--border);
  background:var(--surface);
  overflow-x:auto;
  position:sticky; top:0; z-index:99;
  -webkit-overflow-scrolling:touch;
}
.panel-nav button {
  background:transparent; border:none; color:var(--text-dim);
  font-family:var(--font); font-size:.78rem; font-weight:500;
  padding:.5rem 1rem; border-radius:6px; cursor:pointer;
  white-space:nowrap; transition:all .2s;
}
.panel-nav button:hover { color:var(--text); background:var(--card); }
.panel-nav button.active { color:var(--accent); background:rgba(201,169,98,.1); }

/* === KPI BAR === */
.kpi-bar {
  display:grid;
  grid-template-columns:repeat(auto-fit, minmax(160px,1fr));
  gap:1px;
  background:var(--border);
  margin:1.5rem 2.5rem;
  border-radius:10px;
  overflow:hidden;
}
.kpi-card {
  background:var(--card);
  padding:1.2rem 1.4rem;
  text-align:center;
}
.kpi-label { font-size:.65rem; text-transform:uppercase; letter-spacing:.12em; color:var(--text-mute); margin-bottom:.3rem; font-weight:500; }
.kpi-value { font-size:1.5rem; font-weight:600; color:var(--text); font-family:var(--mono); letter-spacing:-.03em; }
.kpi-sub { font-size:.7rem; color:var(--text-dim); margin-top:.15rem; }

/* === PANELS === */
.panels-wrap { padding:0 2.5rem 2rem; }
.panel { display:none; animation:fadeIn .3s ease; }
.panel.active { display:block; }
@keyframes fadeIn { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:none} }

.panel-header {
  display:flex; justify-content:space-between; align-items:center;
  margin-bottom:1.2rem; padding-top:1.5rem;
}
.panel-title { font-size:1.1rem; font-weight:600; }
.panel-subtitle { font-size:.75rem; color:var(--text-dim); }

/* === BRAND LEADERBOARD === */
.brand-board { display:flex; flex-direction:column; gap:.5rem; }
.brand-row {
  display:grid;
  grid-template-columns:160px 1fr 120px 100px 80px;
  align-items:center;
  gap:1rem;
  padding:.75rem 1rem;
  background:var(--card);
  border-radius:8px;
  border:1px solid var(--border);
  transition:border-color .2s;
}
.brand-row:hover { border-color:var(--border-lt); }
.brand-row .rank { font-size:.75rem; font-weight:600; color:var(--accent); width:1.5rem; text-align:center; }
.brand-row .name { font-size:.85rem; font-weight:500; display:flex; align-items:center; gap:.5rem; }
.brand-bar-wrap { height:24px; background:var(--surface); border-radius:4px; overflow:hidden; position:relative; }
.brand-bar {
  height:100%; border-radius:4px;
  background:linear-gradient(90deg, var(--accent) 0%, var(--accent2) 100%);
  transition:width .8s cubic-bezier(.25,.46,.45,.94);
  min-width:2px;
}
.brand-rev { font-family:var(--mono); font-size:.8rem; font-weight:500; text-align:right; }
.brand-vol { font-size:.75rem; color:var(--text-dim); text-align:right; }
.brand-avg { font-size:.7rem; color:var(--text-mute); text-align:right; }

/* === PRODUCT GRID === */
.filter-bar {
  display:flex; gap:.75rem; flex-wrap:wrap; align-items:center;
  margin-bottom:1rem;
}
.chip-group { display:flex; gap:.35rem; flex-wrap:wrap; }
.chip {
  padding:.35rem .75rem; border-radius:20px;
  font-size:.7rem; font-weight:500; cursor:pointer;
  background:var(--surface); border:1px solid var(--border);
  color:var(--text-dim); transition:all .2s; white-space:nowrap;
}
.chip:hover { border-color:var(--border-lt); color:var(--text); }
.chip.active { background:rgba(201,169,98,.15); border-color:var(--accent); color:var(--accent); }

.sort-bar { display:flex; gap:.35rem; margin-left:auto; }
.sort-btn {
  padding:.35rem .65rem; border-radius:6px;
  font-size:.68rem; font-weight:500; cursor:pointer;
  background:transparent; border:1px solid var(--border);
  color:var(--text-dim); transition:all .2s;
  font-family:var(--font);
}
.sort-btn:hover { color:var(--text); }
.sort-btn.active { background:rgba(201,169,98,.1); border-color:var(--accent); color:var(--accent); }

.products-grid {
  display:grid;
  grid-template-columns:repeat(auto-fill, minmax(260px,1fr));
  gap:.75rem;
}
.product-card {
  background:var(--card);
  border:1px solid var(--border);
  border-radius:10px;
  overflow:hidden;
  transition:all .25s;
  cursor:pointer;
  position:relative;
}
.product-card:hover { border-color:var(--border-lt); transform:translateY(-2px); }
.product-card a { text-decoration:none; color:inherit; display:block; }
.card-img-wrap {
  aspect-ratio:3/4;
  background:var(--surface);
  overflow:hidden;
  position:relative;
}
.card-img-wrap img {
  width:100%; height:100%; object-fit:cover;
  transition:transform .4s;
}
.product-card:hover .card-img-wrap img { transform:scale(1.04); }
.img-placeholder {
  display:flex; align-items:center; justify-content:center;
  width:100%; height:100%; color:var(--text-mute); font-size:.75rem;
}
.card-rank {
  position:absolute; top:.5rem; left:.5rem;
  background:rgba(0,0,0,.7); backdrop-filter:blur(8px);
  color:var(--accent); font-family:var(--mono);
  font-size:.65rem; font-weight:600;
  padding:.2rem .5rem; border-radius:4px;
}
.card-discount {
  position:absolute; top:.5rem; right:.5rem;
  background:var(--red); color:#fff;
  font-size:.6rem; font-weight:600;
  padding:.15rem .4rem; border-radius:4px;
}
.card-body { padding:.75rem .85rem; }
.card-brand { font-size:.6rem; text-transform:uppercase; letter-spacing:.1em; color:var(--accent); font-weight:500; margin-bottom:.2rem; }
.card-title { font-size:.78rem; font-weight:500; color:var(--text); line-height:1.3; margin-bottom:.5rem;
  display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
.card-metrics { display:flex; justify-content:space-between; align-items:flex-end; }
.card-revenue { font-family:var(--mono); font-size:.9rem; font-weight:600; color:var(--green); }
.card-volume { font-size:.7rem; color:var(--text-dim); }
.card-price { font-family:var(--mono); font-size:.75rem; color:var(--text-dim); text-align:right; }
.card-price .full { text-decoration:line-through; color:var(--text-mute); font-size:.65rem; }
.card-velocity {
  position:absolute; bottom:.5rem; left:.5rem;
  background:rgba(0,0,0,.75); backdrop-filter:blur(8px);
  color:var(--teal); font-family:var(--mono);
  font-size:.6rem; font-weight:600;
  padding:.2rem .45rem; border-radius:4px;
  line-height:1;
}
.card-velocity .v-unit { font-size:.5rem; color:var(--text-dim); font-weight:400; }

/* === CATEGORY PANEL === */
.cat-grid {
  display:grid; grid-template-columns:repeat(auto-fill, minmax(280px,1fr));
  gap:.5rem;
}
.cat-row {
  display:grid; grid-template-columns:1fr 100px 70px;
  align-items:center; gap:.75rem;
  padding:.65rem 1rem; background:var(--card);
  border:1px solid var(--border); border-radius:8px;
}
.cat-name { font-size:.8rem; font-weight:500; }
.cat-rev { font-family:var(--mono); font-size:.78rem; text-align:right; color:var(--green); }
.cat-count { font-size:.7rem; color:var(--text-dim); text-align:right; }

/* === PRICE PANEL === */
.price-grid { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
.price-card {
  background:var(--card); border:1px solid var(--border); border-radius:10px;
  padding:1.2rem;
}
.price-card-title { font-size:.8rem; font-weight:600; margin-bottom:1rem; }
.tier-row {
  display:flex; align-items:center; gap:.75rem;
  padding:.35rem 0;
}
.tier-label { font-size:.72rem; color:var(--text-dim); width:80px; }
.tier-bar-wrap { flex:1; height:18px; background:var(--surface); border-radius:3px; overflow:hidden; }
.tier-bar { height:100%; border-radius:3px; transition:width .6s ease; }
.tier-val { font-family:var(--mono); font-size:.7rem; width:60px; text-align:right; }

/* === SCATTER CHART === */
.chart-wrap {
  background:var(--card); border:1px solid var(--border); border-radius:10px;
  padding:1.2rem; position:relative;
}
.chart-canvas { width:100%; }
svg text { font-family:var(--font); }

/* === HIT FINDER === */
.hits-controls {
  display:flex; gap:1rem; flex-wrap:wrap; align-items:center;
  margin-bottom:1rem;
}
.hits-controls label { font-size:.72rem; color:var(--text-dim); }
.hits-controls input[type=range] { width:160px; accent-color:var(--accent); }
.hits-controls .val { font-family:var(--mono); font-size:.75rem; color:var(--accent); min-width:60px; }

.hits-grid {
  display:grid;
  grid-template-columns:repeat(auto-fill, minmax(300px,1fr));
  gap:.75rem;
}
.hit-card {
  display:grid; grid-template-columns:80px 1fr;
  gap:.75rem; padding:.75rem;
  background:var(--card); border:1px solid var(--border);
  border-radius:10px; transition:border-color .2s;
}
.hit-card:hover { border-color:var(--accent); }
.hit-img {
  width:80px; height:100px; object-fit:cover; border-radius:6px;
  background:var(--surface);
}
.hit-img-ph {
  width:80px; height:100px; border-radius:6px;
  background:var(--surface); display:flex;
  align-items:center; justify-content:center;
  color:var(--text-mute); font-size:.6rem;
}
.hit-body {}
.hit-brand { font-size:.6rem; text-transform:uppercase; letter-spacing:.1em; color:var(--accent); font-weight:500; }
.hit-title { font-size:.78rem; font-weight:500; margin:.15rem 0 .4rem; line-height:1.3;
  display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
.hit-stats { display:flex; gap:1rem; }
.hit-stat-label { font-size:.6rem; text-transform:uppercase; letter-spacing:.08em; color:var(--text-mute); }
.hit-stat-val { font-family:var(--mono); font-size:.82rem; font-weight:600; }
.hit-stat-val.rev { color:var(--green); }
.hit-stat-val.vol { color:var(--blue); }
.hit-stat-val.price { color:var(--text-dim); }

/* === PAGINATION === */
.pagination {
  display:flex; justify-content:center; align-items:center; gap:.5rem;
  margin-top:1.5rem;
}
.pagination button {
  padding:.4rem .8rem; border-radius:6px;
  font-size:.75rem; cursor:pointer;
  background:var(--card); border:1px solid var(--border);
  color:var(--text-dim); font-family:var(--font); transition:all .2s;
}
.pagination button:hover { border-color:var(--border-lt); color:var(--text); }
.pagination button.active { background:rgba(201,169,98,.15); border-color:var(--accent); color:var(--accent); }
.pagination button:disabled { opacity:.3; cursor:default; }
.page-info { font-size:.72rem; color:var(--text-mute); }

/* === STATS ROW === */
.stats-row {
  display:flex; gap:1.5rem; padding:.6rem 1rem;
  background:var(--surface); border-radius:8px;
  margin-bottom:1rem; font-size:.72rem;
}
.stats-row .stat { color:var(--text-dim); }
.stats-row .stat strong { color:var(--text); font-weight:600; font-family:var(--mono); }

/* === DISCOUNT PANEL === */
.disc-brand-row {
  display:grid; grid-template-columns:140px 1fr 80px 80px;
  align-items:center; gap:.75rem;
  padding:.6rem 1rem; background:var(--card);
  border:1px solid var(--border); border-radius:8px;
}
.disc-bar-wrap { height:20px; background:var(--surface); border-radius:3px; overflow:hidden; position:relative; }
.disc-bar { height:100%; border-radius:3px; background:var(--red); opacity:.7; }
.disc-pct { font-family:var(--mono); font-size:.75rem; text-align:right; }
.disc-rev { font-family:var(--mono); font-size:.72rem; color:var(--text-dim); text-align:right; }

/* === FOOTER === */
.site-footer {
  text-align:center; padding:2rem;
  border-top:1px solid var(--border);
  font-size:.65rem; color:var(--text-mute);
  margin-top:2rem;
}

/* === SCROLLBAR === */
::-webkit-scrollbar { width:6px; height:6px; }
::-webkit-scrollbar-track { background:transparent; }
::-webkit-scrollbar-thumb { background:var(--border); border-radius:3px; }

/* === MOBILE === */
@media(max-width:768px) {
  .site-header {
  /* not sticky - let it scroll */ padding:1.2rem 1rem .8rem; }
  .header-title { font-size:1.2rem; }
  .panel-nav { padding:.5rem 1rem; }
  .kpi-bar { margin:.8rem 1rem; grid-template-columns:repeat(2,1fr); }
  .panels-wrap { padding:0 1rem 1.5rem; }
  .brand-row { grid-template-columns:1fr 80px; gap:.5rem; }
  .brand-row .brand-bar-wrap { display:none; }
  .brand-row .brand-vol, .brand-row .brand-avg { display:none; }
  .products-grid { grid-template-columns:repeat(2,1fr); gap:.5rem; }
  .filter-bar { flex-direction:column; align-items:stretch; }
  .sort-bar { margin-left:0; }
  .price-grid { grid-template-columns:1fr; }
  .cat-grid { grid-template-columns:1fr; }
  .hits-grid { grid-template-columns:1fr; }
  .hits-controls { flex-direction:column; align-items:stretch; }
  .chip-group { overflow-x:auto; flex-wrap:nowrap; -webkit-overflow-scrolling:touch; }
  .chip-group::-webkit-scrollbar { display:none; }
  .chip { flex-shrink:0; }
  .disc-brand-row { grid-template-columns:100px 1fr 60px; }
  .disc-brand-row .disc-rev { display:none; }
}
@media(max-width:420px) {
  .products-grid { grid-template-columns:1fr; }
  .kpi-value { font-size:1.15rem; }
  .header-title { font-size:1rem; }
}
</style>
</head>
<body>

<!-- HEADER -->
<header class="site-header">
  <div class="header-eyebrow">Best Sellers Intelligence &ensp;&middot;&ensp; 4-Week Revenue Report &ensp;&middot;&ensp; 9 Brands</div>
  <h1 class="header-title">Revenue Leaders<em>Sell-Through Analysis</em></h1>
  <div class="header-period">Jan 22 – Feb 21, 2026 &ensp;|&ensp; Particl Export</div>
</header>

<!-- NAV -->
<nav class="panel-nav" id="panelNav">
  <button class="active" data-panel="overview">Overview</button>
  <button data-panel="products">Products</button>
  <button data-panel="categories">Categories</button>
  <button data-panel="pricing">Pricing</button>
  <button data-panel="hits">Hit Finder</button>
</nav>

<!-- KPI BAR -->
<div class="kpi-bar" id="kpiBar"></div>

<!-- PANELS -->
<div class="panels-wrap">

  <!-- OVERVIEW -->
  <section class="panel active" id="panel-overview">
    <div class="panel-header">
      <div><div class="panel-title">Brand Revenue Leaderboard</div>
      <div class="panel-subtitle">Estimated 4-week revenue by brand</div></div>
    </div>
    <div class="brand-board" id="brandBoard"></div>
  </section>

  <!-- PRODUCTS -->
  <section class="panel" id="panel-products">
    <div class="panel-header">
      <div><div class="panel-title">Product Explorer</div>
      <div class="panel-subtitle" id="productsCount"></div></div>
    </div>
    <div class="filter-bar">
      <div class="chip-group" id="brandChips"></div>
      <div class="sort-bar" id="sortBar">
        <button class="sort-btn active" data-sort="revenue">Revenue ↓</button>
        <button class="sort-btn" data-sort="volume">Volume ↓</button>
        <button class="sort-btn" data-sort="price-hi">Price ↓</button>
        <button class="sort-btn" data-sort="discount">Discount ↓</button>
        <button class="sort-btn" data-sort="velocity">Velocity ↓</button>
      </div>
    </div>
    <div class="products-grid" id="productsGrid"></div>
    <div class="pagination" id="pagination"></div>
  </section>

  <!-- CATEGORIES -->
  <section class="panel" id="panel-categories">
    <div class="panel-header">
      <div><div class="panel-title">Category Revenue Breakdown</div>
      <div class="panel-subtitle">Revenue by product category across all brands</div></div>
    </div>
    <div class="filter-bar">
      <div class="chip-group" id="catBrandChips"></div>
    </div>
    <div id="catChart" class="chart-wrap" style="margin-bottom:1rem;"></div>
    <div class="cat-grid" id="catGrid"></div>
  </section>

  <!-- PRICING -->
  <section class="panel" id="panel-pricing">
    <div class="panel-header">
      <div><div class="panel-title">Price &amp; Discount Intelligence</div>
      <div class="panel-subtitle">Pricing tiers, discount strategies, and revenue efficiency</div></div>
    </div>
    <div class="price-grid" id="priceGrid"></div>
    <div class="panel-header" style="margin-top:1.5rem;">
      <div><div class="panel-title">Discount Strategy by Brand</div>
      <div class="panel-subtitle">% of catalog on discount and revenue from discounted items</div></div>
    </div>
    <div style="display:flex;flex-direction:column;gap:.5rem;" id="discBoard"></div>
  </section>

  <!-- HIT FINDER -->
  <section class="panel" id="panel-hits">
    <div class="panel-header">
      <div><div class="panel-title">Hit Finder</div>
      <div class="panel-subtitle">Products exceeding revenue thresholds — surface breakout performers</div></div>
    </div>
    <div class="filter-bar">
      <div class="chip-group" id="hitBrandChips"></div>
    </div>
    <div class="hits-controls">
      <div>
        <label>Min Revenue</label><br>
        <input type="range" id="hitRevMin" min="0" max="200000" step="5000" value="50000">
        <span class="val" id="hitRevMinVal">£50K</span>
      </div>
      <div>
        <label>Min Volume</label><br>
        <input type="range" id="hitVolMin" min="0" max="500" step="10" value="0">
        <span class="val" id="hitVolMinVal">0</span>
      </div>
      <div>
        <label>Min Velocity (units/day)</label><br>
        <input type="range" id="hitVelMin" min="0" max="20" step="0.5" value="0">
        <span class="val" id="hitVelMinVal">0</span>
      </div>
    </div>
    <div class="stats-row" id="hitStats"></div>
    <div class="hits-grid" id="hitsGrid"></div>
  </section>

</div>

<footer class="site-footer">
  <span>MDV Best Sellers Intelligence &ensp;&middot;&ensp; Feb 2026</span>
